# -------------------------------------------------------------
# GSG Application Checker — environment variables
#
# 1. Copy this file to ".env.local"  (that copy is gitignored, so
#    your real secrets never get committed).
# 2. Fill in the three values from Supabase:
#    Supabase dashboard → Project Settings → API
# 3. Add the SAME three values in Vercel:
#    Vercel project → Settings → Environment Variables
# -------------------------------------------------------------

# Your project URL, e.g. https://abcdefgh.supabase.co  (safe in the browser)
NEXT_PUBLIC_SUPABASE_URL=

# The "anon public" key  (safe in the browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# The "service_role" key — SECRET. Used only on the server for
# reviewer actions. Never expose this in browser code.
SUPABASE_SERVICE_ROLE_KEY=

# -------------------------------------------------------------
# Stripe (payments). Server-only SECRET — never prefix with NEXT_PUBLIC.
# Add this in Vercel → Settings → Environment Variables (and here locally).
# Get it from Stripe → Developers → API keys (sk_test_... or sk_live_...).
# -------------------------------------------------------------
STRIPE_SECRET_KEY=

# Webhook signing secret (whsec_...). Create a webhook endpoint in Stripe
# (Developers → Webhooks) pointing at /api/stripe/webhook, then paste its
# signing secret here. Lets payments be confirmed reliably. Server-only.
STRIPE_WEBHOOK_SECRET=
